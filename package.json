{
  "name": "vet-clinic",
  "private": true,
  "workspaces": [
    "api",
    "web",
    "bot"
  ],
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors blue,green \"npm --workspace api run start:dev\" \"npm --workspace web run dev -- -p 3001\"",
    "lint": "echo 'lint TBD'",
    "build": "echo 'build TBD'",
    "test": "echo 'test TBD'",
    "test:e2e": "npm --workspace web run test:e2e",
    "test:e2e:ui": "npm --workspace web run test:e2e:ui",
    "playwright:install": "npm --workspace web run playwright:install",
    "api:prisma:use:sqlite": "npm --workspace api run prisma:use:sqlite",
    "api:prisma:use:postgres": "npm --workspace api run prisma:use:postgres",
    "api:prisma:generate": "npm --workspace api run prisma:generate",
    "api:prisma:migrate": "npm --workspace api run prisma:migrate",
    "api:prisma:push": "npm --workspace api run prisma:push",
    "api:prisma:seed": "npm --workspace api run prisma:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0"
  }
}
