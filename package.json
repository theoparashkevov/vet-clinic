{
  "name": "vet-clinic",
  "private": true,
  "workspaces": [
    "api",
    "web",
    "bot"
  ],
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors blue,green \"npm --workspace api run start:dev\" \"npm --workspace web run dev -- -p 3001\"",
    "lint": "echo 'lint TBD'",
    "build": "echo 'build TBD'",
    "test": "echo 'test TBD'",
    "test:e2e": "npm --workspace web run test:e2e",
    "test:e2e:ui": "npm --workspace web run test:e2e:ui",
    "playwright:install": "npm --workspace web run playwright:install",
    "api:prisma:use:sqlite": "npm --workspace api run prisma:use:sqlite",
    "api:prisma:use:postgres": "npm --workspace api run prisma:use:postgres",
    "api:prisma:generate": "npm --workspace api run prisma:generate",
    "api:prisma:migrate": "npm --workspace api run prisma:migrate",
    "api:prisma:push": "npm --workspace api run prisma:push",
    "api:prisma:seed": "npm --workspace api run prisma:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/router-devtools": "^1.166.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  }
}
