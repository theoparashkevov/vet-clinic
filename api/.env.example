# Demo (SQLite — no Docker needed)
DATABASE_URL="file:./dev.db"
CORS_ORIGIN="http://localhost:3001,http://localhost:3000"
JWT_SECRET="dev-only-secret"
JWT_EXPIRES_IN="8h"

# SMS Configuration (Twilio)
# Leave these empty to use console logging instead of real SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""  # E.g., +15551234567

# Clinic Info (used in SMS messages)
CLINIC_NAME="Vet Clinic"
CLINIC_PHONE="(555) 123-4567"

# Production (PostgreSQL via Docker)
# DATABASE_URL="postgresql://vet:vet@localhost:5432/vet?schema=public"
# CORS_ORIGIN="http://localhost:3001,http://localhost:3000"
# JWT_SECRET="replace-this-in-production"
