# ============================================
# Vet Clinic API - Environment Variables
# ============================================

# Database Configuration
# ----------------------
# SQLite (Development - No Docker required)
DATABASE_URL="file:./dev.db"

# PostgreSQL (Production via Docker)
# DATABASE_URL="postgresql://vet:vet@localhost:5432/vet?schema=public"

# Server Configuration
# --------------------
PORT=3000
NODE_ENV=development

# CORS Configuration
# ------------------
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3001,http://localhost:3000"

# JWT Authentication
# ------------------
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET="dev-only-secret-change-in-production"
JWT_EXPIRES_IN="8h"

# SMS Configuration (Twilio)
# --------------------------
# Leave these empty to use console logging instead of real SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""  # E.g., +15551234567

# Clinic Information
# ------------------
# Used in SMS messages and notifications
CLINIC_NAME="Vet Clinic"
CLINIC_PHONE="(555) 123-4567"

# ============================================
# Production Environment Variables
# ============================================
# Copy the following variables to your production .env file
# and update with secure values:
#
# DATABASE_URL="postgresql://vet:SECURE_PASSWORD@db:5432/vet?schema=public"
# PORT=3000
# NODE_ENV=production
# CORS_ORIGIN="https://your-domain.com"
# JWT_SECRET="your-secure-random-string-min-32-chars"
# JWT_EXPIRES_IN="8h"
# TWILIO_ACCOUNT_SID="your-twilio-account-sid"
# TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# TWILIO_FROM_NUMBER="+1234567890"
# CLINIC_NAME="Your Vet Clinic Name"
# CLINIC_PHONE="+1 (555) 123-4567"
