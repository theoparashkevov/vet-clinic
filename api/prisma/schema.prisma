generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Owner {
  id           String        @id @default(cuid())
  name         String
  phone        String
  email        String?
  patients     Patient[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

model Patient {
  id                String          @id @default(cuid())
  owner             Owner           @relation(fields: [ownerId], references: [id])
  ownerId           String
  name              String
  species           String
  breed             String?
  birthdate         DateTime?
  microchipId       String?
  notes             String?
  allergies         String?
  chronicConditions String?
  medicalRecords    MedicalRecord[]
  appointments      Appointment[]
  alerts            PatientAlert[]
  vaccinations      Vaccination[]
  weightRecords     WeightRecord[]
  createdAt         DateTime        @default(now())
}

model Appointment {
  id             String          @id @default(cuid())
  patient        Patient         @relation(fields: [patientId], references: [id])
  patientId      String
  owner          Owner           @relation(fields: [ownerId], references: [id])
  ownerId        String
  doctor         User?           @relation(fields: [doctorId], references: [id])
  doctorId       String?
  startsAt       DateTime
  endsAt         DateTime
  reason         String?
  status         String          @default("scheduled")
  medicalRecords MedicalRecord[]
  createdAt      DateTime        @default(now())
}

model MedicalRecord {
  id            String       @id @default(cuid())
  patient       Patient      @relation(fields: [patientId], references: [id])
  patientId     String
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId String?
  visitDate     DateTime
  summary       String
  diagnoses     String?
  treatments    String?
  prescriptions String?
  attachments   String?
  createdAt     DateTime     @default(now())
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  role         String
  passwordHash String?
  appointments Appointment[]
}

model PatientAlert {
  id          String   @id @default(cuid())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId   String
  type        String   // allergy, chronic_condition, medication, behavioral, other
  severity    String   // critical, warning, info
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vaccination {
  id          String   @id @default(cuid())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId   String
  type        String   // rabies, dapp, fvrcp, bordetella, etc.
  name        String   // Human-readable name
  givenDate   DateTime
  dueDate     DateTime
  batchNumber String?
  veterinarian String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WeightRecord {
  id        String   @id @default(cuid())
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId String
  weight    Float    // in kg
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
}
