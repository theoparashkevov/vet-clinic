generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String?
  patients  Patient[]
  createdAt DateTime  @default(now())
}

model Patient {
  id                 String    @id @default(cuid())
  owner              Owner     @relation(fields: [ownerId], references: [id])
  ownerId            String
  name               String
  species            String
  breed              String?
  birthdate          DateTime?
  microchipId        String?
  notes              String?
  allergies          String?
  chronicConditions  String?
  medicalRecords     MedicalRecord[]
  appointments       Appointment[]
  createdAt          DateTime  @default(now())
}

model Appointment {
  id         String   @id @default(cuid())
  patient    Patient  @relation(fields: [patientId], references: [id])
  patientId  String
  owner      Owner    @relation(fields: [ownerId], references: [id])
  ownerId    String
  doctorId   String?
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  status     String   @default("scheduled")
  createdAt  DateTime @default(now())
}

model MedicalRecord {
  id          String   @id @default(cuid())
  patient     Patient  @relation(fields: [patientId], references: [id])
  patientId   String
  visitDate   DateTime
  summary     String
  diagnoses   String?
  treatments  String?
  prescriptions String?
  attachments String?
}

model User {
  id    String @id @default(cuid())
  name  String
  email String @unique
  role  String
}
