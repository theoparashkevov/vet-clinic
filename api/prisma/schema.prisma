generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Owner {
  id           String        @id @default(cuid())
  name         String
  phone        String
  email        String?
  patients     Patient[]
  appointments Appointment[]
  user         User?
  createdAt    DateTime      @default(now())
}

model Patient {
  id                String             @id @default(cuid())
  owner             Owner              @relation(fields: [ownerId], references: [id])
  ownerId           String
  name              String
  species           String
  breed             String?
  birthdate         DateTime?
  microchipId       String?
  notes             String?
  allergies         String?
  chronicConditions String?
  medicalRecords    MedicalRecord[]
  appointments      Appointment[]
  vaccinations      Vaccination[]
  weightRecords     WeightRecord[]
  patientAlerts     PatientAlert[]
  prescriptions     Prescription[]
  photos            PatientPhoto[]
  followUpReminders FollowUpReminder[]
  labResults        LabResult[]
  createdAt         DateTime           @default(now())
}

model Appointment {
  id             String             @id @default(cuid())
  patient        Patient            @relation(fields: [patientId], references: [id])
  patientId      String
  owner          Owner              @relation(fields: [ownerId], references: [id])
  ownerId        String
  doctor         User?              @relation(fields: [doctorId], references: [id])
  doctorId       String?
  startsAt       DateTime
  endsAt         DateTime
  reason         String?
  status         String             @default("scheduled")
  medicalRecords MedicalRecord[]
  followUps      FollowUpReminder[]
  labResults     LabResult[]
  createdAt      DateTime           @default(now())
}

model MedicalRecord {
  id            String       @id @default(cuid())
  patient       Patient      @relation(fields: [patientId], references: [id])
  patientId     String
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId String?
  visitDate     DateTime
  summary       String
  diagnoses     String?
  treatments    String?
  prescriptions String?
  attachments   String?
  createdAt     DateTime     @default(now())
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  role         String
  passwordHash String?
  appointments Appointment[]
  owner        Owner?        @relation(fields: [ownerId], references: [id])
  ownerId      String?       @unique
}

model FollowUpReminder {
  id               String       @id @default(cuid())
  patient          Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId        String
  appointment      Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId    String?
  type             String
  title            String
  description      String?
  dueDate          DateTime
  status           String       @default("pending")
  completedAt      DateTime?
  completedBy      String?
  assignedTo       String?
  priority         String       @default("normal")
  notifyClient     Boolean      @default(false)
  clientNotifiedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedTo])
  @@index([priority])
}

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String    @default("general")
  patientId     String?
  appointmentId String?
  ownerId       String?
  assignedTo    String?
  dueDate       DateTime?
  status        String    @default("pending")
  completedAt   DateTime?
  completedBy   String?
  priority      String    @default("normal")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([priority])
}

model Prescription {
  id               String                @id @default(cuid())
  patient          Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId        String
  medication       String
  dosage           String
  frequency        String
  duration         String
  instructions     String?
  prescribedAt     DateTime              @default(now())
  expiresAt        DateTime
  refillsTotal     Int                   @default(0)
  refillsRemaining Int                   @default(0)
  isControlled     Boolean               @default(false)
  veterinarian     String
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  // Inventory relation
  transactions     InventoryTransaction[]
  refillRequests   RefillRequest[]

  @@index([patientId])
  @@index([prescribedAt])
}

model MedicationTemplate {
  id           String          @id @default(cuid())
  name         String
  category     String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  isCommon     Boolean         @default(false)
  createdAt    DateTime        @default(now())

  // Inventory relation
  inventoryItem InventoryItem?

  @@index([category])
  @@index([isCommon])
}

model NoteTemplate {
  id        String   @id @default(cuid())
  name      String
  category  String
  content   String
  isCommon  Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())

  @@index([category])
  @@index([isCommon])
}

model PatientPhoto {
  id           String   @id @default(cuid())
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId    String
  url          String
  thumbnailUrl String?
  category     String
  description  String?
  takenAt      DateTime
  uploadedAt   DateTime @default(now())
  uploadedBy   String
  fileSize     Int
  mimeType     String

  @@index([patientId])
  @@index([category])
  @@index([takenAt])
}

model Vaccination {
  id            String   @id @default(cuid())
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId     String
  type          String
  name          String
  givenDate     DateTime
  dueDate       DateTime
  batchNumber   String?
  veterinarian  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
  @@index([dueDate])
}

model WeightRecord {
  id          String   @id @default(cuid())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId   String
  weight      Float
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
  @@index([date])
}

model PatientAlert {
  id          String   @id @default(cuid())
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId   String
  type        String
  severity    String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
  @@index([severity])
}

// ── Lab Results ──────────────────────────────────────────────────────────────

model LabPanel {
  id            String     @id @default(cuid())
  name          String     // e.g., "Complete Blood Count", "Chemistry Panel"
  category      String     // "Hematology", "Chemistry", "Urinalysis", "Endocrine"
  description   String?
  tests         LabTest[]
  labResults    LabResult[]
  isCommon      Boolean    @default(false)
  species       String?    // "dog", "cat", or null for all
  createdAt     DateTime   @default(now())
  
  @@index([category])
  @@index([isCommon])
  @@index([species])
}

model LabTest {
  id                String     @id @default(cuid())
  panel             LabPanel   @relation(fields: [panelId], references: [id], onDelete: Cascade)
  panelId           String
  name              String     // e.g., "White Blood Cell Count"
  abbreviation      String?    // e.g., "WBC"
  unit              String     // e.g., "K/µL", "mg/dL"
  
  // Reference ranges by species
  refRangeDogMin    Float?
  refRangeDogMax    Float?
  refRangeCatMin    Float?
  refRangeCatMax    Float?
  
  // Critical values
  criticalLow       Float?     // Below this is critically low
  criticalHigh      Float?     // Above this is critically high
  
  // Severity thresholds
  warningLow        Float?     // Below this is mildly low
  warningHigh       Float?     // Above this is mildly high
  
  resultValues      LabResultValue[]
  sortOrder         Int        @default(0)
  createdAt         DateTime   @default(now())
  
  @@index([panelId])
  @@index([sortOrder])
}

model LabResult {
  id              String           @id @default(cuid())
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId       String
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id])
  appointmentId   String?
  
  // Panel information
  panel           LabPanel         @relation(fields: [panelId], references: [id])
  panelId         String
  
  // Result details
  testDate        DateTime
  receivedDate    DateTime?        // When results came back
  reviewedDate    DateTime?        // When vet reviewed
  reviewedBy      String?          // Veterinarian name
  
  // Status
  status          String           @default("pending") // "pending", "complete", "reviewed", "abnormal"
  
  // Individual test values
  values          LabResultValue[]
  
  // Summary
  abnormalCount   Int              @default(0)
  criticalCount   Int              @default(0)
  
  // Notes
  notes           String?
  interpretation  String?          // Veterinarian's interpretation
  
  // File attachment
  pdfUrl          String?          // URL to lab report PDF
  externalLab     String?          // e.g., "IDEXX", "Antech", "In-house"
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([patientId])
  @@index([testDate])
  @@index([status])
  @@index([panelId])
}

model LabResultValue {
  id              String      @id @default(cuid())
  labResult       LabResult   @relation(fields: [labResultId], references: [id], onDelete: Cascade)
  labResultId     String

  test            LabTest     @relation(fields: [testId], references: [id])
  testId          String

  // The actual value
  value           Float
  displayValue    String      // Formatted for display

  // Status flags (calculated automatically)
  status          String      @default("normal") // "normal", "low", "high", "critical_low", "critical_high"

  // Reference range used (based on species)
  refRangeMin     Float?
  refRangeMax     Float?

  // Previous value for comparison
  previousValue   Float?
  trend           String?     // "up", "down", "stable" - calculated from previous

  notes           String?

  @@index([labResultId])
  @@index([testId])
  @@index([status])
}

// ── Client Portal ────────────────────────────────────────────────────────────

model ClientPortalUser {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  ownerId   String   @unique
  owner     Owner    @relation(fields: [ownerId], references: [id])
  password  String   // hashed
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastLogin DateTime?

  @@index([ownerId])
}

model RefillRequest {
  id              String       @id @default(cuid())
  prescriptionId  String
  prescription    Prescription @relation(fields: [prescriptionId], references: [id])
  clientId        String       // ClientPortalUser id
  status          String       @default("pending") // pending, approved, denied
  requestedAt     DateTime     @default(now())
  respondedAt     DateTime?
  notes           String?
  respondedBy     String?      // Staff user who responded

  @@index([prescriptionId])
  @@index([clientId])
  @@index([status])
}

// ── Inventory Management ─────────────────────────────────────────────────────

model InventoryItem {
  id              String   @id @default(cuid())
  name            String
  category        String   // VACCINE, MEDICATION, SUPPLY, FOOD, EQUIPMENT
  sku             String?  @unique
  description     String?
  
  // Stock tracking
  quantity        Int      @default(0)
  minQuantity     Int      @default(10)
  unit            String   // vial, tablet, bottle, ml
  
  // Expiration
  expirationDate  DateTime?
  lotNumber       String?
  
  // Supplier info
  supplier        String?
  supplierSku     String?
  costPerUnit     Float?
  
  // Link to medication template (optional)
  medicationTemplateId String? @unique
  medicationTemplate   MedicationTemplate? @relation(fields: [medicationTemplateId], references: [id])
  
  // Tracking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  transactions    InventoryTransaction[]
  
  @@index([category])
  @@index([quantity])
  @@index([expirationDate])
}

model InventoryTransaction {
  id              String   @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  type            String   // RECEIVED, DISPENSED, ADJUSTED, EXPIRED, RETURNED
  quantity        Int              // positive for received, negative for dispensed
  
  // Context
  prescriptionId  String?  // if dispensed via prescription
  prescription    Prescription? @relation(fields: [prescriptionId], references: [id])
  
  notes           String?
  performedById   String   // staff user
  performedBy     User     @relation(fields: [performedById], references: [id])
  
  createdAt       DateTime @default(now())
  
  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
  @@index([prescriptionId])
}
