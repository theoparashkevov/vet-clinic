{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "veterinary-doctor": {
      "description": "A veterinary doctor agent that diagnoses and treats animal illnesses based on symptoms, medical history, and test results.",
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.5",
      "prompt": "{file:./veterinary-doctor/prompt.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}